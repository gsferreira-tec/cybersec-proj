$TTL 60
@   IN  SOA     ns1.attacker.test. admin.attacker.test. (
                  2026052303 ; Serial (YYYYMMDDNN)
                  3600       ; Refresh
                  900        ; Retry
                  604800     ; Expire
                  86400 )    ; Minimum TTL

@    IN  NS      ns1.attacker.test.
@    IN  MX  10  mail.attacker.test.
@    IN  A 	 10.9.0.7
ns1  IN  A       10.9.0.5
mail IN  A       10.9.0.7
*    IN  A       10.9.0.7

; --- SPOOFING INFRASTRUCTURE ---

; === TEST MODE: SPF (attacker domain) — uncomment ONE ===
@   IN  TXT     "v=spf1 ip4:10.9.0.7 +all"                      ; permissive — authorizes attacker host (current)
;@  IN  TXT     "v=spf1 ip4:10.9.0.7 -all"                      ; strict but still self-authorized
;@  IN  TXT     "v=spf1 -all"                                   ; deny all — useful to show SPF blocking attacker
; (none active)                                                 ; no SPF record at all

; === TEST MODE: DKIM (attacker's published pubkey) — uncomment ONE ===
mail._domainkey IN TXT ( "v=DKIM1; k=rsa; p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDNjwdrmp/gcbKLaGQfRZk+LJ6XOWuQXkAOa/lI1En4t4sLuWiKiL6hACqMrsKQ8XfgqN76mmx4CHWn2VqVewFh7QTvshGLywWwrAJZdQ4KTlfR/2EwAlrItndijOfr2tpZRgP0nTY6saktkhQdwrk3U0SZmG7U8L9IPj7ZwPKGvQIDAQAB" )   ; valid attacker key (current)
;mail._domainkey IN TXT ( "v=DKIM1; k=rsa; p=" )                                                                                                                                                                                                                                                                                                                                                                                                  ; revoked — signatures will fail
; (none active)                                                                                                                                                                                                                                                                                                                                                                                                                                       ; no DKIM record — verification fails outright

; === TEST MODE: DMARC (attacker domain) — uncomment ONE ===
_dmarc IN TXT  "v=DMARC1; p=none;    aspf=r; adkim=r"           ; relaxed alignment, monitor only (current)
;_dmarc IN TXT "v=DMARC1; p=reject;  aspf=s; adkim=s"           ; strict — to show how alignment breaks spoofing
;_dmarc IN TXT "v=DMARC1; p=quarantine; aspf=r; adkim=r"        ; quarantine
